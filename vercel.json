{
  "rewrites": [
    {
      "source": "/((?!admin\\.html|data|covers|assets|manifest\\.json|sw\\.js|scripts).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/covers/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
